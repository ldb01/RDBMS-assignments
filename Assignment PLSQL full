-- 10. Sum of First 100 Odd Numbers
DECLARE
  total NUMBER := 0;
BEGIN
  FOR i IN 1..100 LOOP
    total := total + (2*i - 1);
  END LOOP;

  DBMS_OUTPUT.PUT_LINE('Sum = ' || total);
END;
/

