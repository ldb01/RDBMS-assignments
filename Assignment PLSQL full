-- 2. Salary Grade
DECLARE
  sal NUMBER := &salary;
BEGIN
  IF sal >= 50000 THEN
    DBMS_OUTPUT.PUT_LINE('Grade A');
  ELSIF sal >= 30000 THEN
    DBMS_OUTPUT.PUT_LINE('Grade B');
  ELSE
    DBMS_OUTPUT.PUT_LINE('Grade C');
  END IF;
END;
/

