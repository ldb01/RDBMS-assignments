-- 11. Insert Employee Procedure
CREATE OR REPLACE PROCEDURE add_emp(p_no NUMBER, p_name VARCHAR2) AS
BEGIN
  INSERT INTO employee(emp_no, name) VALUES (p_no, p_name);
END;
/

-- 12. Display Employee Details
CREATE OR REPLACE PROCEDURE emp_details(p_no NUMBER) AS
BEGIN
  FOR r IN (SELECT name, designation, salary FROM employee WHERE emp_no = p_no) LOOP
    DBMS_OUTPUT.PUT_LINE(r.name || ' ' || r.designation || ' ' || r.salary);
  END LOOP;
END;
/

-- 13. OUT Parameter Procedure
CREATE OR REPLACE PROCEDURE emp_info(
  p_no IN NUMBER,
  p_name OUT VARCHAR2,
  p_dept OUT VARCHAR2
) AS
BEGIN
  SELECT e.name, d.dept_name
  INTO p_name, p_dept
  FROM employee e JOIN department d
  ON e.dept_id = d.dept_id
  WHERE e.emp_no = p_no;
END;
/

-- 14. Display Grade in Department
CREATE OR REPLACE PROCEDURE emp_grade(p_dept NUMBER) AS
BEGIN
  FOR r IN (
    SELECT name,
    CASE
      WHEN salary >= 50000 THEN 'A'
      WHEN salary >= 30000 THEN 'B'
      ELSE 'C'
    END grade
    FROM employee
    WHERE dept_id = p_dept
  ) LOOP
    DBMS_OUTPUT.PUT_LINE(r.name || ' Grade ' || r.grade);
  END LOOP;
END;
/

-- 15. Total Salary Function
CREATE OR REPLACE FUNCTION total_salary_dept(p_dept NUMBER)
RETURN NUMBER AS
  total NUMBER;
BEGIN
  SELECT SUM(salary) INTO total
  FROM employee
  WHERE dept_id = p_dept;
  RETURN total;
END;
/

-- 16. Count Employee Function
CREATE OR REPLACE FUNCTION count_emp_dept(p_dept NUMBER)
RETURN NUMBER AS
  cnt NUMBER;
BEGIN
  SELECT COUNT(*) INTO cnt
  FROM employee
  WHERE dept_id = p_dept;
  RETURN cnt;
END;
/

-- 17. Bonus Function
CREATE OR REPLACE FUNCTION calc_bonus(p_sal NUMBER)
RETURN NUMBER AS
BEGIN
  RETURN p_sal * 0.20;
END;
/

-- 18. Show Employee
CREATE OR REPLACE PROCEDURE show_emp(p_id NUMBER) AS
BEGIN
  FOR r IN (
    SELECT e.name, e.salary, d.dept_name
    FROM employee e JOIN department d
    ON e.dept_id = d.dept_id
    WHERE e.emp_no = p_id
  ) LOOP
    DBMS_OUTPUT.PUT_LINE(r.name || ' ' || r.salary || ' ' || r.dept_name);
  END LOOP;
END;
/

-- 19. Update Salary Procedure
CREATE OR REPLACE PROCEDURE update_salary(p_id NUMBER, p_per NUMBER) AS
BEGIN
  UPDATE employee
  SET salary = salary + (salary * p_per / 100)
  WHERE emp_no = p_id;
END;
/

-- 20. Calculate Age Function
CREATE OR REPLACE FUNCTION calculate_age(p_id NUMBER)
RETURN NUMBER AS
  dob DATE;
BEGIN
  SELECT date_of_birth INTO dob
  FROM employee
  WHERE emp_no = p_id;

  RETURN FLOOR(MONTHS_BETWEEN(SYSDATE, dob) / 12);
END;
/

