-- 23. Increase SALES by 10%
DECLARE
  CURSOR c IS
    SELECT emp_no, salary FROM employee WHERE dept_id = 40;
BEGIN
  FOR r IN c LOOP
    DBMS_OUTPUT.PUT_LINE('Old: ' || r.salary);
    UPDATE employee
    SET salary = salary * 1.10
    WHERE emp_no = r.emp_no;
    DBMS_OUTPUT.PUT_LINE('New: ' || r.salary * 1.10);
  END LOOP;
END;
/

-- 24. Implicit Cursor
BEGIN
  UPDATE employee SET salary = salary + 1000;

  IF SQL%ROWCOUNT = 0 THEN
    DBMS_OUTPUT.PUT_LINE('None of the salaries were updated');
  ELSE
    DBMS_OUTPUT.PUT_LINE('Salaries for ' || SQL%ROWCOUNT || ' employees updated');
  END IF;
END;
/

-- 25. Top 5 Highest Paid
DECLARE
  CURSOR c IS
    SELECT * FROM employee
    ORDER BY salary DESC
    FETCH FIRST 5 ROWS ONLY;
BEGIN
  FOR r IN c LOOP
    DBMS_OUTPUT.PUT_LINE(r.name || ' ' || r.salary);
  END LOOP;
END;
/
