-- 5. Fibonacci Series
DECLARE
  a NUMBER := 0;
  b NUMBER := 1;
  c NUMBER;
BEGIN
  DBMS_OUTPUT.PUT_LINE(a);
  DBMS_OUTPUT.PUT_LINE(b);
  FOR i IN 1..8 LOOP
    c := a + b;
    DBMS_OUTPUT.PUT_LINE(c);
    a := b;
    b := c;
  END LOOP;
END;
/

-- 6. Using %TYPE
DECLARE
  v_name employee.name%TYPE;
  v_sal  employee.salary%TYPE;
BEGIN
  SELECT name, salary INTO v_name, v_sal
  FROM employee
  WHERE emp_no = &emp_no;

  DBMS_OUTPUT.PUT_LINE(v_name || ' ' || v_sal);
END;
/

-- 7. Reverse Number
DECLARE
  n NUMBER := &num;
  rev NUMBER := 0;
BEGIN
  WHILE n > 0 LOOP
    rev := rev * 10 + MOD(n,10);
    n := FLOOR(n/10);
  END LOOP;
  DBMS_OUTPUT.PUT_LINE('Reverse: ' || rev);
END;
/

-- 8. Department using CASE
DECLARE
  did NUMBER := &dept_id;
  dname VARCHAR2(20);
BEGIN
  dname :=
    CASE did
      WHEN 10 THEN 'Finance'
      WHEN 20 THEN 'HR'
      WHEN 30 THEN 'IT'
      WHEN 40 THEN 'Sales'
      ELSE 'Invalid Department'
    END;

  DBMS_OUTPUT.PUT_LINE(dname);
END;
/

