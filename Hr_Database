-- =========================
-- BASIC SQL QUERIES
-- =========================

-- Q1: Display all details of employees
SELECT * FROM emp;

-- Q2: Display employee name and salary
SELECT ename, sal FROM emp;

-- Q3: Display employee name and department number
SELECT ename, deptno FROM emp;

-- Q4: Display distinct job titles
SELECT DISTINCT job FROM emp;

-- Q5: Display employees in department 30
SELECT * FROM emp WHERE deptno = 30;

-- Q6: Employees with salary > 2000
SELECT * FROM emp WHERE sal > 2000;

-- Q7: Employees hired after 01-JAN-1981
SELECT * FROM emp WHERE hiredate > '1981-01-01';

-- Q8: Employees whose name starts with S
SELECT * FROM emp WHERE ename LIKE 'S%';

-- Q9: Employees with no commission
SELECT * FROM emp WHERE comm IS NULL OR comm = 0;

-- Q10: Employees in dept 10 or 20
SELECT * FROM emp WHERE deptno IN (10,20);

-- Q11: All employees sorted by salary descending
SELECT * FROM emp ORDER BY sal DESC;

-- Q12: Employee name, salary, commission sorted by name
SELECT ename, sal, comm FROM emp ORDER BY ename;

-- Q13: Employees with no manager
SELECT * FROM emp WHERE mgr IS NULL;

-- Q14: Location of department 20
SELECT loc FROM dept WHERE deptno = 20;

-- Q15: Departments sorted alphabetically
SELECT * FROM dept ORDER BY dname;

-- Q16: Employees with salary between 1000 and 3000
SELECT * FROM emp WHERE sal BETWEEN 1000 AND 3000;

-- Q17: Count employees
SELECT COUNT(*) FROM emp;

-- Q18: Min and Max salary
SELECT MIN(sal), MAX(sal) FROM emp;

-- Q19: Total employees per job
SELECT job, COUNT(*) FROM emp GROUP BY job;

-- Q20: Current system date
SELECT CURDATE();


-- =========================
-- MODERATE LEVEL
-- =========================

-- Q21: Name, salary, yearly salary
SELECT ename, sal, sal*12 AS yearly_salary FROM emp;

-- Q22: Employees joined in 1981
SELECT * FROM emp WHERE YEAR(hiredate) = 1981;

-- Q23: Employees sorted by hiredate descending
SELECT * FROM emp ORDER BY hiredate DESC;

-- Q24: Average salary per department
SELECT deptno, AVG(sal) FROM emp GROUP BY deptno;

-- Q25: Employee name with department name
SELECT e.ename, d.dname 
FROM emp e 
JOIN dept d ON e.deptno = d.deptno;

-- Q26: Employees earning more than avg salary
SELECT * FROM emp 
WHERE sal > (SELECT AVG(sal) FROM emp);

-- Q27: Employees with commission
SELECT * FROM emp WHERE comm IS NOT NULL AND comm > 0;

-- Q28: Names containing 'A'
SELECT * FROM emp WHERE ename LIKE '%A%';

-- Q29: Highest salary per job
SELECT job, MAX(sal) FROM emp GROUP BY job;

-- Q30: Employees in NEW YORK
SELECT e.* 
FROM emp e 
JOIN dept d ON e.deptno = d.deptno
WHERE d.loc = 'NEW YORK';

-- Q31: Employees hired on Monday
SELECT * FROM emp WHERE DAYNAME(hiredate) = 'Monday';

-- Q32: Count employees without commission
SELECT COUNT(*) FROM emp WHERE comm IS NULL OR comm = 0;

-- Q33: Total commission per job
SELECT job, SUM(comm) FROM emp GROUP BY job;

-- Q34: Departments with more than 3 employees
SELECT deptno, COUNT(*) 
FROM emp 
GROUP BY deptno 
HAVING COUNT(*) > 3;

-- Q35: Second highest salary
SELECT MAX(sal) 
FROM emp 
WHERE sal < (SELECT MAX(sal) FROM emp);

-- Q36: Same job as SMITH
SELECT * FROM emp 
WHERE job = (SELECT job FROM emp WHERE ename = 'SMITH');

-- Q37: Salary grade using SALGRADE
SELECT e.ename, e.sal, s.grade
FROM emp e
JOIN salgrade s 
ON e.sal BETWEEN s.losal AND s.hisal;

-- Q38: Name, salary, grade
SELECT e.ename, e.sal, s.grade
FROM emp e
JOIN salgrade s 
ON e.sal BETWEEN s.losal AND s.hisal;

-- Q39: Employees who are managers
SELECT * FROM emp 
WHERE empno IN (SELECT DISTINCT mgr FROM emp WHERE mgr IS NOT NULL);

-- Q40: Highest salary in dept 30
SELECT * FROM emp 
WHERE deptno = 30 
AND sal = (SELECT MAX(sal) FROM emp WHERE deptno = 30);




-- =========================
-- ADVANCED SQL (41–80)
-- =========================

-- Q41: Highest salary in company
SELECT * FROM emp 
WHERE sal = (SELECT MAX(sal) FROM emp);

-- Q42: Employees earning more than avg salary of their department
SELECT * FROM emp e
WHERE sal > (
    SELECT AVG(sal) FROM emp 
    WHERE deptno = e.deptno
);

-- Q43: Department with maximum total salary
SELECT deptno, SUM(sal) total_sal
FROM emp
GROUP BY deptno
ORDER BY total_sal DESC
LIMIT 1;

-- Q44: Employees who joined before their manager
SELECT e.* 
FROM emp e
JOIN emp m ON e.mgr = m.empno
WHERE e.hiredate < m.hiredate;

-- Q45: Departments with no employees
SELECT * FROM dept
WHERE deptno NOT IN (SELECT DISTINCT deptno FROM emp);

-- Q46: Third highest salary
SELECT DISTINCT sal FROM emp
ORDER BY sal DESC
LIMIT 1 OFFSET 2;

-- Q47: Employees hired month-wise count
SELECT MONTH(hiredate), COUNT(*) 
FROM emp
GROUP BY MONTH(hiredate);

-- Q48: Employees who joined after FORD
SELECT * FROM emp
WHERE hiredate > (
    SELECT hiredate FROM emp WHERE ename='FORD'
);

-- Q49: Employees whose dept not in DEPT table
SELECT * FROM emp
WHERE deptno NOT IN (SELECT deptno FROM dept);

-- Q50: Job + difference between max & min salary
SELECT job, MAX(sal)-MIN(sal) AS diff
FROM emp
GROUP BY job;

-- Q51: Name + length of name
SELECT ename, LENGTH(ename) FROM emp;

-- Q52: Salary formatted to 2 decimal
SELECT ename, FORMAT(sal,2) FROM emp;

-- Q53: Mask name after 3 chars
SELECT CONCAT(LEFT(ename,3),'****') FROM emp;

-- Q54: Replace NULL commission
SELECT ename, IFNULL(comm,'No Commission') FROM emp;

-- Q55: Create view
CREATE VIEW emp_view AS
SELECT e.ename, e.sal, d.dname
FROM emp e JOIN dept d ON e.deptno = d.deptno;

-- Q56: Increase salary of dept 30 by 10%
UPDATE emp 
SET sal = sal * 1.10 
WHERE deptno = 30;

-- Q57: Delete employees without department
DELETE FROM emp 
WHERE deptno NOT IN (SELECT deptno FROM dept);

-- Q58: Insert new department
INSERT INTO dept VALUES (50,'HR','DELHI');

-- Q59: Employees in same dept as BLAKE
SELECT * FROM emp
WHERE deptno = (
    SELECT deptno FROM emp WHERE ename='BLAKE'
);

-- Q60: Jobs appearing more than once
SELECT job FROM emp
GROUP BY job
HAVING COUNT(*) > 1;

-- Q61: Salary greater than max salary of dept 10
SELECT * FROM emp
WHERE sal > (
    SELECT MAX(sal) FROM emp WHERE deptno=10
);

-- Q62: More than every employee in dept 30
SELECT * FROM emp
WHERE sal > ALL (
    SELECT sal FROM emp WHERE deptno=30
);

-- Q63: Departments where all have commission
SELECT deptno FROM emp
GROUP BY deptno
HAVING COUNT(*) = COUNT(comm);

-- Q64: Salary equals dept avg
SELECT * FROM emp e
WHERE sal = (
    SELECT AVG(sal) FROM emp 
    WHERE deptno = e.deptno
);

-- Q65: Salary below job avg
SELECT * FROM emp e
WHERE sal < (
    SELECT AVG(sal) FROM emp 
    WHERE job = e.job
);

-- Q66: Min salary per job
SELECT * FROM emp e
WHERE sal = (
    SELECT MIN(sal) FROM emp 
    WHERE job = e.job
);

-- Q67: Same city as KING
SELECT e.* FROM emp e
JOIN dept d ON e.deptno = d.deptno
WHERE d.loc = (
    SELECT d.loc FROM emp e2 
    JOIN dept d ON e2.deptno = d.deptno
    WHERE e2.ename='KING'
);

-- Q68: Salary not in any grade
SELECT * FROM emp e
WHERE NOT EXISTS (
    SELECT * FROM salgrade s
    WHERE e.sal BETWEEN s.losal AND s.hisal
);

-- Q69: Second highest salary per dept
SELECT deptno, MAX(sal) FROM emp e1
WHERE sal < (
    SELECT MAX(sal) FROM emp e2 
    WHERE e1.deptno = e2.deptno
)
GROUP BY deptno;

-- Q70: Dept with at least one manager
SELECT DISTINCT deptno FROM emp
WHERE job='MANAGER';

-- Q71: Departments with no manager
SELECT deptno FROM dept
WHERE deptno NOT IN (
    SELECT DISTINCT deptno FROM emp WHERE job='MANAGER'
);

-- Q72: Highest grade employees
SELECT e.* FROM emp e
JOIN salgrade s ON e.sal BETWEEN s.losal AND s.hisal
WHERE s.grade = (SELECT MAX(grade) FROM salgrade);

-- Q73: Same salary as someone in another dept
SELECT * FROM emp e1
WHERE EXISTS (
    SELECT * FROM emp e2
    WHERE e1.sal = e2.sal 
    AND e1.deptno <> e2.deptno
);

-- Q74: Earliest hire per dept
SELECT * FROM emp e
WHERE hiredate = (
    SELECT MIN(hiredate) FROM emp 
    WHERE deptno = e.deptno
);

-- Q75: Dept with less than avg employees
SELECT deptno FROM emp
GROUP BY deptno
HAVING COUNT(*) < (
    SELECT AVG(cnt) FROM (
        SELECT COUNT(*) cnt FROM emp GROUP BY deptno
    ) t
);

-- Q76: Manager in different location
SELECT e.* FROM emp e
JOIN emp m ON e.mgr = m.empno
JOIN dept d1 ON e.deptno = d1.deptno
JOIN dept d2 ON m.deptno = d2.deptno
WHERE d1.loc <> d2.loc;

-- Q77: Dept with highest total salary
SELECT deptno FROM emp
GROUP BY deptno
ORDER BY SUM(sal) DESC
LIMIT 1;

-- Q78: Dept + employees earning above avg of managers
SELECT DISTINCT deptno FROM emp
WHERE sal > (
    SELECT AVG(sal) FROM emp WHERE job='MANAGER'
);

-- Q79: Employees earning more than their manager
SELECT e.* FROM emp e
JOIN emp m ON e.mgr = m.empno
WHERE e.sal > m.sal;

-- Q80: Name, salary, dept name for grade 3
SELECT e.ename, e.sal, d.dname
FROM emp e
JOIN dept d ON e.deptno = d.deptno
JOIN salgrade s ON e.sal BETWEEN s.losal AND s.hisal
WHERE s.grade = 3;
